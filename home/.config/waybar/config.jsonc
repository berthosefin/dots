{
  "layer": "top",
  "spacing": 0,
  "position": "top",
  "margin-top": 1,
  "margin-bottom": 0,
  "margin-left": 2,
  "margin-right": 2,
  "modules-left": [
    "custom/launcher",
    "custom/divider",
    "clock",
    "hyprland/workspaces",
  ],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "tray",
    "custom/divider",
    "pulseaudio",
    "backlight",
    "network",
    "custom/divider",
    "group/hardware",
    "custom/divider",
    "group/group-power",
  ],
  "hyprland/workspaces": {
    "format": "{name}",
    "show-special": true,
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "(.*) â€” Mozilla Firefox": "ًںŒژ $1",
      "^$": "THOS",
    },
    "separate-outputs": true,
    "tooltip": false,
    "expand": true,
  },
  "clock": {
    "format": "ï€— {:%H:%M}",
    "format-alt": "îھ° {:%d %b, %Y}",
    "tooltip-format": "{calendar}",
    "calendar": {
      "mode": "month",
      "format": {
        "today": "<b><u>{}</u></b>",
      },
    },
  },
  "tray": {
    "spacing": 10,
    "tooltip": false,
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%ïٹ”",
    "format-muted": "ï€¦",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "ï€¨ ",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "î»¨îŒ­",
      "headphone": "ï€¥",
      "hands-free": "ï–گ",
      "headset": "ï–گ",
      "phone": "ï‚•",
      "phone-muted": "î´—",
      "portable": "ï‚•",
      "car": "ï†¹",
      "default": ["ï€§", "ï€¨"],
    },
    "scroll-step": 1,
    "on-click": "pamixer -t",
    "on-click-right": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"],
    "tooltip": false,
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["َ°ƒœ", "َ°ƒ›", "َ°ƒڑ"],
    "tooltip": false,
  },
  "network": {
    "interface": "wlo1",
    "format": "{ifname}",
    "format-wifi": "ï‡«  {signalStrength}%",
    "format-ethernet": "َ°ٹ—  {ifname}",
    "format-disconnected": "ï‡« !", //An empty format will hide the module.
    "tooltip-format": "َ°ٹ—  {ifname} via {gwaddr}",
    "tooltip-format-wifi": "ï‡«  {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "ïƒپ  {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "networkmanager_dmenu",
  },
  "cpu": {
    "interval": 10,
    "format": "ï‹› {usage}%",
    "max-length": 10,
  },
  "memory": {
    "interval": 30,
    "format": "ïƒ‰ {percentage}%",
    "max-length": 10,
  },
  "battery": {
    "bat": "BAT1",
    "interval": 10,
    "states": {
      "full-at": 96,
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon} {capacity}%",
    "format-icons": ["َ°پ»", "َ°پ½", "َ°پ؟", "َ°‚پ", "َ°پ¹"],
    "max-length": 25,
  },
  "custom/launcher": {
    "format": "ïŒƒ",
    "tooltip": false,
    "on-click": "rofi -show drun",
  },
  "custom/power": {
    "format": "âڈ»",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm-action.sh poweroff",
  },
  "custom/quit": {
    "format": "َ°—¼",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm-action.sh quit",
  },
  "custom/suspend": {
    "format": "âڈ¾",
    "tooltip": false,
    "on-click": "systemctl suspend",
  },
  "custom/lock": {
    "format": "َ°چپ",
    "tooltip": false,
    "on-click": "hyprlock",
  },
  "custom/reboot": {
    "format": "َ°œ‰",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm-action.sh reboot",
  },
  "custom/divider": {
    "format": "|",
    "tooltip": false,
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false,
    },
    "modules": ["battery", "cpu", "memory"],
  },
  "group/group-power": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/power",
      "custom/quit",
      "custom/lock",
      "custom/suspend",
      "custom/reboot",
    ],
  },
}
